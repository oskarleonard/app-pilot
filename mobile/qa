#!/bin/bash
# COMPAT ALIAS (one migration cycle) — remove once every rig calls `app-pilot`
# directly and sets APP_PILOT_PROJECT_DIR. Old rig shims exec `<harness>/mobile/qa`
# and export QA_PROJECT_QA_DIR; this forwards to the renamed `app-pilot` engine
# and bridges the old env var so nothing breaks mid-rename.
export APP_PILOT_PROJECT_DIR="${APP_PILOT_PROJECT_DIR:-${QA_PROJECT_QA_DIR:-}}"
exec "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/app-pilot" "$@"
